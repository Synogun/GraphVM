{
  "name": "graphvm",
  "version": "1.2.0",
  "main": "src/main.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "utils:upgrade-check": "npx npm-check-updates",
    "utils:upgrade": "npx npm-check-updates -u",
    "utils:lint": "npx eslint src",
    "utils:lint:fix": "npx eslint src --fix",
    "utils:clean-dev": "rimraf build",
    "utils:clean-docs": "rimraf docs",
    "build:lint": "npm run utils:lint",
    "build:tailwind": "npx tailwindcss -i src/css/style.css -o docs/css/style.css --minify",
    "build:bundle": "esbuild src/main.tsx --outfile=docs/js/bundle.js --bundle --platform=browser",
    "build:copy": "cpx \"src/www/**/*\" docs",
    "build": "run-s -l build:*",
    "start:prod": "http-server docs -o -c-1",
    "start:tailwind": "npx tailwindcss -i src/www/style.css -o build/style.css --watch --minify",
    "start:cpx": "cpx \"src/www/**/*\" build -i \"*.css\" --watch --update",
    "start:bundler": "esbuild src/main.tsx --outfile=build/js/bundle.js --bundle --servedir=build --watch --sourcemap=linked",
    "prestart:dev": "npm run utils:clean-dev",
    "start:dev": "run-p start:cpx start:tailwind start:bundler"
  },
  "keywords": [],
  "author": "Synogun",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@stylistic/eslint-plugin": "5.2.2",
    "@types/cytoscape": "3.21.9",
    "@types/jquery": "3.5.32",
    "@types/node": "24.1.0",
    "@types/react": "19.1.9",
    "@types/react-dom": "19.1.7",
    "cpx2": "8.0.0",
    "daisyui": "5.0.50",
    "esbuild": "0.25.8",
    "eslint": "9.32.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "http-server": "14.1.1",
    "npm-check-updates": "18.0.2",
    "npm-run-all": "4.1.5",
    "rimraf": "6.0.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.38.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "4.1.11",
    "browserify": "17.0.1",
    "cytoscape": "3.33.0",
    "jquery": "3.7.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-icons": "5.5.0",
    "tailwindcss": "4.1.11"
  }
}
