{
  "name": "graphvm",
  "version": "1.0.0",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "utils:copy-static": "cpx src/public/**/* build",
    "utils:lint": "eslint src",
    "bundle": "esbuild src/main.ts --outfile=build/bundle.js --bundle --platform=browser",
    "build": "rimraf build && npm run utils:copy-static && npm run bundle",
    "release": "npm run build && rimraf release && cpx build/**/* release --verbose",
    "start:cpx": "cpx src/public/**/* build --watch --verbose --update",
    "start:server": "http-server build -o -c-1",
    "start:bundler": "esbuild src/main.ts --outfile=build/bundle.js --bundle --platform=browser --watch --sourcemap",
    "start:prod": "http-server release -o -c-1",
    "start:dev": "rimraf build && start npm run start:cpx && start npm run start:server && npm run start:bundler"
  },
  "keywords": [],
  "author": "Synogun",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/js": "^9.18.0",
    "@stylistic/eslint-plugin": "^2.12.1",
    "@types/node": "^22.10.5",
    "cpx2": "^8.0.0",
    "esbuild": "0.24.2",
    "eslint": "^9.18.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  },
  "dependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/jquery": "^3.5.32",
    "browserify": "^17.0.1",
    "cytoscape": "^3.31.0",
    "jquery": "^3.7.1"
  }
}
