        "@stylistic/eslint-plugin": "5.3.1",
        "@types/cytoscape": "3.21.9",
        "@types/node": "24.4.0",
        "@types/react": "19.1.13",
        "@types/react-dom": "19.1.9",
        "@vitejs/plugin-react": "5.0.2",
        "eslint": "9.35.0",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-react-refresh": "0.4.20",
        "globals": "16.4.0",
        "npm-check-updates": "18.1.1",
